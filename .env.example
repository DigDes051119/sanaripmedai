# Пул ключей DeepSeek (через запятую)
DEEPSEEK_API_KEYS=key1,key2,key3
DEEPSEEK_API_KEY=ваш_deepseek_api_key
DEEPSEEK_API_KEY_SECONDARY=ваш_резервный_deepseek_api_key

# Резервные ключи OpenRouter (для перенаправления при падении DeepSeek)
OPENROUTER_API_KEYS=op_key1,op_key2

# Пул ключей Google Gemini (для анализа фото, бесплатно)
GEMINI_API_KEYS=gemini_key1,gemini_key2,gemini_key3

# Пул ключей Groq (Whisper и резервный Vision)
GROQ_API_KEYS=groq_key1,groq_key2,groq_key3
GROQ_API_KEY=ваш_основной_groq_api_key

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=ваш_telegram_bot_token

# ─── Шифрование персональных данных (AES/Fernet) ────────────────────────────
# Генерируйте ОДИН РАЗ командой:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Полученный ключ сохраните в секретах Hugging Face Spaces (Settings → Variables and secrets)
# ВАЖНО: потеря этого ключа сделает зашифрованные ПДн НЕВОССТАНОВИМЫМИ
PII_ENCRYPTION_KEY=сгенерируйте_ключ_командой_выше

# Twilio account credentials
TWILIO_ACCOUNT_SID=ваш_twilio_sid
TWILIO_AUTH_TOKEN=ваш_twilio_auth_token

# Twilio WhatsApp Sandbox номер (в формате whatsapp:+14155238886)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Настройки семантического кэша (0.95 = 95% векторного сходства)
SEMANTIC_CACHE_THRESHOLD=0.95

